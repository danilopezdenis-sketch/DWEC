{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/usuarios",
      "methods": ["GET", "POST"],
      "dest": "api/index.js"
    },
    {
      "src": "/usuarios/(.*)",
      "methods": ["DELETE"],
      "dest": "api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ]
}
